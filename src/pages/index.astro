---
// index.astro (or whatever your main page is named)
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Skills from '../components/Skills.astro';
---

<MainLayout title="Madueke Chinemerem | Junior Developer">
    
    <section class="mb-16 pt-10">
        <h1 class="text-5xl font-extrabold text-white mb-6 tracking-tight">
            Hi, I'm <span class="text-blue-500">Madueke Chinemerem</span>.
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
            I'm a Junior Software Developer focused on building clean, efficient, and accessible web experiences. Currently exploring software engineering internship opportunities.I am a second-year Software Engineering student at Pan-Atlantic University with a strong foundation in front-end development. I specialize in building responsive, API-driven web applications using JavaScript, React, and Next.js. While my current skill set lies in creating well balanced user interfaces, I am open to learn and expanding my skill set into back-end development and cybersecurity to become a versatile engineer.
        </p>
         
        <div class="mt-8 flex gap-4">
            <a href="mailto:chinemeremmadueke1@gmail.com" class="bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-6 rounded-md transition-colors">
                Contact Me
            </a>
            <a href="https://github.com/chiboy-star" target="_blank" rel="noopener noreferrer" class="border border-slate-600 hover:border-slate-400 hover:bg-slate-800 text-slate-300 py-2 px-6 rounded-md transition-all">
                GitHub Profile
            </a>
            <a href="www.linkedin.com/in/chinemerem-madueke-b75038294" target="_blank" rel="noopener noreferrer" class="border border-slate-600 hover:border-slate-400 hover:bg-slate-800 text-slate-300 py-2 px-6 rounded-md transition-all">
                linkedin Profile
            </a>
        </div>
    </section>

    <Skills />

    <section>
        <h2 class="text-2xl font-bold text-white mb-8 border-b border-slate-700 pb-2">
            Featured Projects
        </h2>
        
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            
            <ProjectCard 
                title="Influencer Marketing Web-App"
                description="Serving as Front-end Lead for this platform connecting brands with creators. Built dynamic dashboards and seamless user flows."
                tags={['Next.js', 'Tailwind CSS', 'React']}
                repoLink="https://caskayd-sprint-frontend.vercel.app"
                liveLink="https://caskayd-sprint-frontend.vercel.app" 
            />

            <ProjectCard 
                title="Smart Calculator"
                description="A modern, glassmorphism-styled calculator featuring custom logic for rapid thousands (K) and millions (M) multiplier inputs."
                tags={['JavaScript', 'HTML5', 'CSS3']}
                repoLink="https://github.com/chiboy-star/calculator-project"
            />

            <ProjectCard 
                title="Secure Password Generator"
                description="A cryptographically secure password generation tool with a responsive UI, utilizing window.crypto for true randomness."
                tags={['JavaScript', 'DOM Manipulation', 'CSS3']}
                repoLink="https://github.com/chiboy-star/password_generator"
            />

        </div>
    </section>

</MainLayout>