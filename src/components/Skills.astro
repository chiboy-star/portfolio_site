---
import { Icon } from 'astro-icon/components';

const skills = [
  { name: 'JavaScript', icon: 'simple-icons:javascript', color: 'text-yellow-400' },
  { name: 'TypeScript', icon: 'simple-icons:typescript', color: 'text-blue-500' },
  { name: 'React', icon: 'simple-icons:react', color: 'text-cyan-400' },
  { name: 'Tailwind', icon: 'simple-icons:tailwindcss', color: 'text-cyan-300' },
  { name: 'Node.js', icon: 'simple-icons:nodedotjs', color: 'text-green-500' },
  { name: 'Git', icon: 'simple-icons:git', color: 'text-orange-500' },
];
---

<section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 border-b border-slate-700 pb-2">
        Technical Skills
    </h2>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-4">
        {skills.map((skill) => (
            <div class="flex flex-col items-center p-4 bg-slate-800/50 rounded-lg hover:bg-slate-800 transition-colors border border-slate-700 hover:border-slate-600">
                <Icon name={skill.icon} class={`w-8 h-8 mb-2 ${skill.color}`} />
                <span class="text-sm font-medium text-slate-300">{skill.name}</span>
            </div>
        ))}
    </div>
</section>