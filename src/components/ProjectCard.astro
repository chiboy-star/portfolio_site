---
interface Props {
	title: string;
	description: string;
	tags: string[];
	link: string;
}

const { title, description, tags, link } = Astro.props;
---

<a href={link} target="_blank" class="block group hover:no-underline">
    <div class="border border-slate-700 p-6 rounded-lg bg-slate-800/50 hover:bg-slate-800 transition-all hover:border-blue-500/50">
        <h3 class="text-xl font-bold text-white group-hover:text-blue-400 mb-2">
            {title} &rarr;
        </h3>
        <p class="text-slate-400 mb-4 text-sm leading-relaxed">
            {description}
        </p>
        <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
                <span class="text-xs font-medium px-2.5 py-0.5 rounded bg-blue-900 text-blue-300 border border-blue-800">
                    {tag}
                </span>
            ))}
        </div>
    </div>
</a>