---
// ProjectCard.astro
interface Props {
    title: string;
    description: string;
    tags: string[];
    repoLink: string;
    liveLink?: string; // Made optional with the '?'
}

const { title, description, tags, repoLink, liveLink } = Astro.props;
---

<div class="border border-slate-700 p-6 rounded-lg bg-slate-800/50 hover:bg-slate-800 transition-all hover:border-blue-500/50 flex flex-col h-full">
    <h3 class="text-xl font-bold text-white mb-2">
        {title}
    </h3>
    <p class="text-slate-400 mb-4 text-sm leading-relaxed flex-grow">
        {description}
    </p>
    
    <div class="flex flex-wrap gap-2 mb-6">
        {tags.map((tag) => (
            <span class="text-xs font-medium px-2.5 py-0.5 rounded bg-blue-900/50 text-blue-300 border border-blue-800">
                {tag}
            </span>
        ))}
    </div>

    <div class="flex gap-3 mt-auto pt-4 border-t border-slate-700/50">
        <a href={repoLink} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white flex items-center gap-1 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            Code
        </a>
        
        {liveLink && (
            <a href={liveLink} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-400 hover:text-blue-300 flex items-center gap-1 transition-colors ml-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Live Demo
            </a>
        )}
    </div>
</div>